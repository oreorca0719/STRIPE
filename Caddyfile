# STRIPE 엣지 프록시 — Let's Encrypt 인증서 자동 발급·갱신
#
# 도메인 미구매 상태이므로 nip.io(IP→호스트명 무료 DNS)를 사용한다.
# 도메인 구매 시 아래 호스트명만 교체하면 된다.
#
# Caddy가 frontend(nginx)로 프록시하고, nginx가 SPA 서빙 + /api → backend 프록시.

54-180-21-185.nip.io {
	encode gzip
	reverse_proxy frontend:80
}

# IP로 직접 접근한 경우(인증서 없음) → HTTPS 호스트명으로 안내 리다이렉트
:80 {
	redir https://54-180-21-185.nip.io{uri} permanent
}
